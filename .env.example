# ===============================
# TELEGRAM CONFIGURATION
# ===============================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ===============================
# SOC ANALYST CONFIGURATION
# ===============================
ANALYST_NAME=Your Name Here
ANALYST_ROLE=SOC Analyst

# ===============================
# DATABASE CONFIGURATION
# ===============================
DB_TYPE=sqlite  # Options: sqlite, postgresql, mysql
DB_PATH=./data/soc_alerts.db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=soc_automation
DB_USER=admin
DB_PASSWORD=secure_password_here

# ===============================
# THREAT INTELLIGENCE
# ===============================
THREAT_INTEL_API_KEY=your_api_key_here
VIRUS_TOTAL_API_KEY=your_virustotal_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_key_here

# ===============================
# ML & LOGGING
# ===============================
ML_MODEL_PATH=./models/alert_dedup_model.pkl
AUDIT_LOG_PATH=./logs/audit.log
MAX_ALERT_HISTORY=10000

# ===============================
# SECURITY
# ===============================
SECRET_KEY=your_secret_key_for_encryption
DEBUG_MODE=false
ALLOW_CORS=false
CORS_ORIGINS=localhost:8501

# ===============================
# THREAT FEED (Live Threats)
# ===============================
OTX_API_KEY=your_alien_vault_otx_key
THREAT_FEED_UPDATE_INTERVAL=300  # seconds
ENABLE_LIVE_THREAT_MAP=true

# ===============================
# PERFORMANCE
# ===============================
CACHE_ENABLED=true
CACHE_TTL=3600
THREAD_POOL_SIZE=4
